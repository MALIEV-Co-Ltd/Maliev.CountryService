{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Microsoft.EntityFrameworkCore": "Warning",
      "Microsoft.AspNetCore.Watch.BrowserRefresh": "None",
      "Microsoft.Hosting.Lifetime": "Information",
      "Microsoft.AspNetCore.Watch": "Warning",
      "System": "Warning"
    }
  },
  "AllowedHosts": "*",
  "CacheOptions": {
    "FreshTtlMinutes": 15,
    "GracePeriodMinutes": 5
  },
  "CORS": {
    "AllowedOrigins": []
  },
  "RateLimiting": {
    "ReadEndpoints": {
      "PermitLimit": 100,
      "Window": "00:01:00"
    },
    "AdminEndpoints": {
      "PermitLimit": 20,
      "Window": "00:01:00"
    }
  }
}